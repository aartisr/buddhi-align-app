# Buddhi Align - plug-and-play environment template
# Copy this file to apps/frontend/.env.local for local development.

# Core app mode
# Options: memory | supabase
DATA_PROVIDER=memory

# Supabase (required when DATA_PROVIDER=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public URLs
# NEXT_PUBLIC_API_URL is optional for same-origin API usage.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CLARITY_PROJECT_ID=w90fdbtt4x

# Community integration
# Leave COMMUNITY_PROXY_TARGET unset for the native /community pages.
COMMUNITY_INTEGRATION_PROVIDER=discourse
DISCOURSE_INTEGRATION_ENABLED=true
DISCOURSE_BASE_URL=https://community.foreverlotus.com
NEXT_PUBLIC_DISCOURSE_COMMUNITY_URL=http://localhost:3000/community
DISCOURSE_PARENT_CATEGORY_SLUG=buddhi-align
DISCOURSE_DEFAULT_CATEGORY_SLUG=buddhi-align
DISCOURSE_REQUEST_TIMEOUT_MS=4000
DISCOURSE_API_USERNAME=
DISCOURSE_API_KEY=
DISCOURSE_SSO_SECRET=

# Admin access gate
ADMIN_PASSWORD=change-me

# Optional background music
NEXT_PUBLIC_BGM_URL=
NEXT_PUBLIC_BGM_URLS=

# Auth runtime
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_URL=
NEXTAUTH_URL=

# OAuth providers (configure only what you use)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

AUTH_MICROSOFT_ENTRA_ID=
AUTH_MICROSOFT_ENTRA_SECRET=
AUTH_MICROSOFT_ENTRA_TENANT_ID=

AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

AUTH_APPLE_ID=
AUTH_APPLE_SECRET=
AUTH_APPLE_KEY_ID=
AUTH_APPLE_TEAM_ID=

AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=
