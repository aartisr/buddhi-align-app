{
  "name": "buddhi-align-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npm --workspace=apps/frontend run test",
    "test:frontend": "npm --workspace=apps/frontend run test",
    "lint": "npm --workspace=apps/frontend run lint",
    "lint:frontend": "npm --workspace=apps/frontend run lint",
    "dev": "npm --workspace=apps/frontend run dev",
    "dev:frontend": "npm --workspace=apps/frontend run dev",
    "build": "npm --workspace=apps/frontend run build",
    "build:frontend": "npm --workspace=apps/frontend run build",
    "start:frontend": "npm --workspace=apps/frontend run start",
    "perf:lighthouse": "mkdir -p apps/frontend/.lighthouseci && npx --yes lighthouse http://127.0.0.1:3000 --chrome-flags='--headless=new --no-sandbox --disable-dev-shm-usage' --preset=desktop --only-categories=performance --budgets-path=apps/frontend/lighthouse-budget.json --output=json --output-path=apps/frontend/.lighthouseci/report.json --quiet",
    "perf:budget": "node scripts/check-performance-budget.mjs apps/frontend/.lighthouseci/report.json",
    "perf:ci": "npm run start:frontend >/tmp/buddhi-start.log 2>&1 & echo $! >/tmp/buddhi-start.pid; i=0; until curl -fsS http://127.0.0.1:3000 >/dev/null; do i=$((i+1)); if [ $i -ge 60 ]; then echo 'Server failed to start'; kill $(cat /tmp/buddhi-start.pid) 2>/dev/null || true; exit 1; fi; sleep 2; done; npm run perf:lighthouse && npm run perf:budget; status=$?; kill $(cat /tmp/buddhi-start.pid) 2>/dev/null || true; exit $status"
  },
  "keywords": [],
  "author": "Aarti Sri Ravikumar",
  "license": "ISC",
  "workspaces": [
    "apps/frontend",
    "packages/*"
  ],
  "devDependencies": {
    "@types/estree": "^1.0.8",
    "npm-run-all": "^4.1.5"
  },
  "overrides": {
    "eslint": "8.57.1"
  }
}
