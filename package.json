{
  "name": "buddhi-align-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npm-run-all test:frontend test:backend",
    "test:frontend": "npm --workspace=apps/frontend run test",
    "test:backend": "npm --workspace=apps/backend run test",
    "lint": "npm-run-all lint:frontend",
    "lint:frontend": "npm --workspace=apps/frontend run lint",
    "dev:frontend": "npm --workspace=apps/frontend run dev",
    "dev:backend": "npm --workspace=apps/backend run dev",
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "build:frontend": "npm --workspace=apps/frontend run build",
    "build:backend": "npm --workspace=apps/backend run build",
    "build": "npm-run-all build:frontend build:backend"
  },
  "keywords": [],
  "author": "Aarti Sri Ravikumar",
  "license": "ISC",
  "dependencies": {},
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "overrides": {
    "eslint": "8.57.1"
  }
}